---
const { title = "Matrimonio" } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isMatrimonio = currentPath.startsWith("/matrimonio");
const isSupermercado = currentPath.startsWith("/supermercado");
const isMatrimonioInicio = currentPath === "/matrimonio/inicio";
const isMatrimonioInvitacion = currentPath === "/matrimonio/invitacion";
const isMatrimonioGaleria = currentPath === "/matrimonio/galeria";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Boda de Consuelo y Fabián" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="main-nav">
        <ul class="main-nav-list">
          <li>
            <a
              href="/"
              class={isHome ? "nav-link active-link disabled-link" : "nav-link"}
            >
              Inicio
            </a>
          </li>
          <li>
            <a
              href="/matrimonio/inicio"
              class={isMatrimonio ? "nav-link active-link" : "nav-link"}
            >
              Matrimonio
            </a>
          </li>
          <li>
            <a
              href="/supermercado/"
              class={isSupermercado
                ? "nav-link active-link disabled-link"
                : "nav-link"}
            >
              Supermercado
            </a>
          </li>
        </ul>
      </nav>

      {isMatrimonio && (
        <nav class="matrimonio-subheader" aria-label="Navegacion matrimonio">
          <ul class="subheader-list">
            <li>
              <a
                href="/matrimonio/inicio"
                class={isMatrimonioInicio
                  ? "subheader-link active-link disabled-link"
                  : "subheader-link"}
              >
                Inicio
              </a>
            </li>
            <li>
              <a
                href="/matrimonio/invitacion"
                class={isMatrimonioInvitacion
                  ? "subheader-link active-link disabled-link"
                  : "subheader-link"}
              >
                Invitacion
              </a>
            </li>
            <li>
              <a
                href="/matrimonio/galeria"
                class={isMatrimonioGaleria
                  ? "subheader-link active-link disabled-link"
                  : "subheader-link"}
              >
                Galeria
              </a>
            </li>
          </ul>
        </nav>
      )}
    </header>

    <slot />
  </body>
</html>
